# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Environment variables (NEVER commit these) ───────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── Build output ─────────────────────────────────────────────────────────────
/frontend/build
/backend/dist

# ─── Uploaded files (user profile pictures etc.) ─────────────────────────────
/backend/uploads/*
!/backend/uploads/.gitkeep

# ─── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS & Editor artifacts ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ─── Testing ──────────────────────────────────────────────────────────────────
/coverage
