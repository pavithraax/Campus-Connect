# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# MongoDB connection string
# Local:   mongodb://127.0.0.1:27017/campus-connect
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/campus-connect
MONGO_URI=mongodb://127.0.0.1:27017/campus-connect

# JWT secret — use a long random string in production
JWT_SECRET=your_super_secret_key_change_this

# Port the backend runs on
PORT=5000

# URL of the React frontend (for CORS)
FRONTEND_ORIGIN=http://localhost:3000
